#!/usr/bin/env python3
#MISE description="Run integration tests"
#MISE depends=["test-rust"]

import subprocess
import sys
import time

server = None
try:
    server = subprocess.Popen(
        ["./target/debug/slowcial-web"],
        cwd="web",
        env={**__import__("os").environ, "DATABASE_PATH": ":memory:"},
    )
    time.sleep(1)
    if server.poll() is not None:
        print(f"Server exited early with code {server.returncode}", file=sys.stderr)
        sys.exit(1)
    result = subprocess.run(["hurl", "--test"] + sorted(__import__("glob").glob("integration-tests/*.hurl")))
    sys.exit(result.returncode)
finally:
    if server and server.poll() is None:
        server.terminate()
        try:
            server.wait(timeout=5)
        except subprocess.TimeoutExpired:
            server.kill()
            server.wait()
